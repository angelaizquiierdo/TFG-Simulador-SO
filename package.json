{
  "name": "cpu-scheduler",
  "version": "1.0.0",
  "description": "CPU Scheduling Simulator — librería TypeScript + componente React",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "dist/index.d.ts",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "npm --workspace docs run dev",
    "docs:build": "npm --workspace docs run build"
  },
  "repository": {
